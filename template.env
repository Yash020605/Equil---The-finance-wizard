# =============================================================================
#  Equil — The Finance Wizard | Environment Template
#
#  This file is safe to commit. It documents every required variable with
#  descriptions and example values but contains NO real secrets.
#
#  Usage:
#    1. Copy this file: cp template.env .env
#    2. Fill in each empty value in .env
#    3. Never commit .env
# =============================================================================


# -----------------------------------------------------------------------------
# APPLICATION SECURITY
# -----------------------------------------------------------------------------

# HS256 secret used to sign and verify JWT Bearer tokens.
# Must be a cryptographically random string (minimum 256 bits / 32 bytes).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<generate-with-secrets.token_hex(32)>


# -----------------------------------------------------------------------------
# LLM & AI AGENTS — NVIDIA NIM (Nemotron)
# -----------------------------------------------------------------------------

# NVIDIA API key for NIM inference endpoint (free tier available).
# Obtain: https://build.nvidia.com  → click any model → "Get API Key"
NVIDIA_API_KEY=nvapi-...

# Nemotron model identifier passed to ChatNVIDIA.
# Options:
#   nvidia/nemotron-4-340b-instruct   (flagship, best reasoning)
#   nvidia/nemotron-mini-4b-instruct  (faster, lower cost)
NVIDIA_MODEL=nvidia/nemotron-4-340b-instruct


# -----------------------------------------------------------------------------
# GOOGLE CLOUD — VISION API (Primary OCR)
# -----------------------------------------------------------------------------

# Absolute filesystem path to your Google service account JSON key file.
# The service account must have the "Cloud Vision API User" role.
# Obtain: https://console.cloud.google.com/iam-admin/serviceaccounts
#
# Linux/Mac example : /home/user/keys/equil-vision-sa.json
# Windows example   : C:\keys\equil-vision-sa.json
GOOGLE_APPLICATION_CREDENTIALS=<absolute-path-to-service-account.json>


# -----------------------------------------------------------------------------
# DATABASE — POSTGRESQL (LangGraph Checkpointer)
# -----------------------------------------------------------------------------

# Credentials used by docker-compose to initialise the postgres container
# and by the backend to construct DATABASE_URL.
POSTGRES_USER=<your-db-username>
POSTGRES_PASSWORD=<generate-strong-password>
POSTGRES_DB=equil_db
POSTGRES_PORT=5432

# Full async DSN consumed by AsyncPostgresSaver and SQLAlchemy.
# Interpolation uses the variables defined above.
# Local dev : replace @localhost with @postgres when running inside docker-compose.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}


# -----------------------------------------------------------------------------
# CORS — ALLOWED ORIGINS
# -----------------------------------------------------------------------------

# Comma-separated list of origins the FastAPI CORS middleware will accept.
# Add your Vercel/Railway production domain here for deployed environments.
# Example: http://localhost:3000,https://equil.vercel.app
ALLOWED_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# FRONTEND — NEXT.JS
# -----------------------------------------------------------------------------

# Public base URL of the FastAPI backend, injected into the Next.js build.
# Must be reachable from the browser (not a docker-internal hostname).
# Development : http://localhost:8000
# Production  : https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# UPLOAD CONSTRAINTS
# -----------------------------------------------------------------------------

# Hard cap on incoming file size (bytes). Default = 20 MB.
# Requests exceeding this limit receive HTTP 413.
MAX_UPLOAD_BYTES=20971520

# Comma-separated MIME types accepted by the /extract/upload endpoint.
# Requests with any other type receive HTTP 415.
ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,text/csv,application/pdf


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Maximum number of requests per minute per IP for the upload endpoint.
# Exceeding this limit returns HTTP 429.
RATE_LIMIT_PER_MINUTE=10


# -----------------------------------------------------------------------------
# ENVIRONMENT TAG
# -----------------------------------------------------------------------------

# Controls logging verbosity and debug behaviour.
# Valid values: development | staging | production
APP_ENV=development

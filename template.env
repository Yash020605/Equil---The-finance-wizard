# Equil Environment Variables Template
# Copy this file to '.env' and populate the actual secrets.

# Application Security
JWT_SECRET=your_jwt_secret_here

# LLM & AI Agents
OPENAI_API_KEY=sk-your_openai_api_key

# Google Cloud (Vision API)
# Paste the JSON payload of your service account credentials here or point to the file path
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", ...}

# Database Connectivity (LangGraph Postgres Checkpointer)
DATABASE_URL=postgresql+asyncpg://equil_user:password@localhost:5432/equil_db

# Frontend Connectivity
NEXT_PUBLIC_API_URL=http://localhost:8000
